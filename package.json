{
  "name": "magnetic-grid",
  "version": "0.1.0",
  "description": "Interactive magnetic grid background for React — points that attract or repel the cursor, rendered on canvas. Mesh, lines and dots variants, four presets, custom renderer, reduced-motion aware.",
  "type": "module",
  "author": "Dominik Pawlikowski",
  "license": "MIT",
  "main": "./dist/magnetic-grid.js",
  "module": "./dist/magnetic-grid.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/magnetic-grid.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/demo",
    "!src/test"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib",
    "build:lib": "cross-env BUILD_MODE=lib vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.lib.json",
    "build:demo": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test:run && npm run build:lib"
  },
  "keywords": [
    "react",
    "canvas",
    "magnetic",
    "grid",
    "background",
    "interactive",
    "cursor",
    "animation",
    "particles",
    "generative",
    "hero"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dpawlikowski/magnetic-grid"
  },
  "homepage": "https://github.com/dpawlikowski/magnetic-grid#readme",
  "bugs": {
    "url": "https://github.com/dpawlikowski/magnetic-grid/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.16.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
